<UserControl x:Class="ThreadBeacon.App.Controls.TokenInfoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="16"
             Height="16"
             Focusable="False"
             Unloaded="OnUnloaded">
    <Grid>
        <Button x:Name="InfoButton"
                Width="16"
                Height="16"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                AutomationProperties.Name="{DynamicResource ViewTokenDetails}"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Click="OnInfoButtonClick"
                KeyDown="OnInfoButtonKeyDown"
                MouseEnter="OnTriggerMouseEnter"
                MouseLeave="OnTriggerMouseLeave">
            <TextBlock FontFamily="Segoe Fluent Icons"
                       FontSize="12"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="&#xE946;" />
        </Button>

        <Popup x:Name="DetailsPopup"
               AllowsTransparency="True"
               Closed="OnPopupClosed"
               HorizontalOffset="-8"
               Placement="Left"
               PlacementTarget="{Binding ElementName=InfoButton}"
               PopupAnimation="Fade"
               StaysOpen="False">
            <Border x:Name="PopupContent"
                    Width="270"
                    Padding="12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    MouseEnter="OnPopupMouseEnter"
                    MouseLeave="OnPopupMouseLeave">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14"
                                      Direction="270"
                                      Opacity="0.18"
                                      ShadowDepth="3" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Text="{DynamicResource TokenDetails}" />

                    <ItemsControl Margin="0,10,0,0"
                                  Grid.IsSharedSizeScope="True"
                                  ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="TokenLabel" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="{Binding Label}" />
                                    <TextBlock Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="12"
                                               Text="{Binding Value}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Height="1"
                            Margin="0,4,0,8"
                            Background="{StaticResource ControlBorderBrush}" />

                    <TextBlock FontSize="10"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="{Binding Note}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
