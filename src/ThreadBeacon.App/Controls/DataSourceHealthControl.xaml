<UserControl x:Class="ThreadBeacon.App.Controls.DataSourceHealthControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="22"
             Height="22"
             Focusable="False"
             Unloaded="OnUnloaded">
    <Grid>
        <Button x:Name="HealthButton"
                Width="22"
                Height="22"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                AutomationProperties.Name="{Binding Details.AccessibilityLabel, ElementName=Root}"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Click="OnHealthButtonClick"
                KeyDown="OnHealthButtonKeyDown"
                ToolTip="{Binding Details.AccessibilityLabel, ElementName=Root}">
            <Grid Width="16" Height="16">
                <TextBlock x:Name="HealthButtonBaseGlyph"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Segoe Fluent Icons"
                           FontSize="16"
                           Foreground="{Binding Details.OverallBrush, ElementName=Root}"
                           Text="{Binding Details.HealthButtonBaseGlyph, ElementName=Root}" />
                <TextBlock x:Name="HealthButtonOverlayGlyph"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Segoe Fluent Icons"
                           FontSize="9"
                           Foreground="{Binding Details.OverallBrush, ElementName=Root}"
                           Text="{Binding Details.HealthButtonOverlayGlyph, ElementName=Root}" />
            </Grid>
        </Button>

        <Popup x:Name="DetailsPopup"
               AllowsTransparency="True"
               HorizontalOffset="-8"
               Placement="Top"
               PlacementTarget="{Binding ElementName=HealthButton}"
               PopupAnimation="Fade"
               StaysOpen="False"
               VerticalOffset="-6">
            <Border x:Name="PopupContent"
                    Width="320"
                    Padding="14"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Border.Resources>
                    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
                </Border.Resources>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14"
                                      Direction="270"
                                      Opacity="0.18"
                                      ShadowDepth="3" />
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="14"
                                   Foreground="{Binding OverallBrush}"
                                   Text="{Binding OverallGlyph}" />
                        <TextBlock Grid.Column="2"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource DataSourceHealth}" />
                        <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding Summary}" />
                    </Grid>

                    <TextBlock Margin="0,7,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding LastSuccessfulRefreshText}" />

                    <Border Height="1"
                            Margin="0,10,0,10"
                            Background="{DynamicResource ControlBorderBrush}" />

                    <ItemsControl ItemsSource="{Binding Sources}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,9">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Top"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="12"
                                               Foreground="{Binding Brush}"
                                               Text="{Binding Glyph}" />
                                    <StackPanel Grid.Column="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="11"
                                                       Text="{Binding Title}" />
                                            <TextBlock Grid.Column="1"
                                                       FontSize="11"
                                                       Foreground="{Binding Brush}"
                                                       Text="{Binding StatusText}" />
                                        </Grid>
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Text="{Binding DetailText}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasDetail, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Text="{Binding SupplementalText}"
                                                   Visibility="{Binding HasSupplementalText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
