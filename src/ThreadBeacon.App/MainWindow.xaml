<Window x:Class="ThreadBeacon.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ThreadBeacon.App.Controls"
        Title="ThreadBeacon for Codex"
        Icon="Resources/AppIcon.ico"
        Width="620"
        Height="500"
        MinWidth="480"
        MinHeight="340"
        Background="{StaticResource WindowBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        Topmost="{Binding WindowPin.IsPinned}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="#E5484D" />
                <Ellipse Width="9" Height="9" Margin="0,3" Fill="#F5A524" />
                <Ellipse Width="9" Height="9" Fill="#30A46C" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="ThreadBeacon" />
                <TextBlock Margin="0,2,0,0"
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="Codex 任务状态" />
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource ControlBorderBrush}"
                        Command="{Binding WindowPin.ToggleCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="钉在最前面" />
                            <Setter Property="AutomationProperties.Name" Value="钉在最前面" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WindowPin.IsPinned}" Value="True">
                                    <Setter Property="ToolTip" Value="取消钉住" />
                                    <Setter Property="AutomationProperties.Name" Value="取消钉住" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE718;" />
                                <Setter Property="Foreground"
                                        Value="{StaticResource SecondaryTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowPin.IsPinned}" Value="True">
                                        <Setter Property="Text" Value="&#xE841;" />
                                        <Setter Property="Foreground" Value="#0067C0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Button Width="32"
                        Height="32"
                        Padding="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource ControlBorderBrush}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="刷新">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="15"
                               Text="&#xE72C;" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="14,0,14,7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="66" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="48" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="状态" />
            <TextBlock Grid.Column="2"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="任务" />
            <TextBlock Grid.Column="3"
                       HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="累计 Token" />
            <TextBlock Grid.Column="4"
                       HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="持续" />
        </Grid>

        <Grid Grid.Row="3">
            <ListBox ItemsSource="{Binding Threads}"
                     Visibility="{Binding ListVisibility}"
                     Background="{StaticResource SurfaceBrush}"
                     BorderBrush="{StaticResource ControlBorderBrush}"
                     BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Focusable" Value="False" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Height="48"
                                Padding="13,0"
                                BorderBrush="#ECECEE"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="66" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="8"
                                         Height="8"
                                         HorizontalAlignment="Left"
                                         Fill="{Binding StatusBrush}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Text="{Binding StatusLabel}" />
                                <TextBlock Grid.Column="2"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Title}" />
                                <StackPanel Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="11"
                                               Text="{Binding TokenText}" />
                                    <controls:TokenInfoControl Margin="4,0,0,0"
                                                               Details="{Binding TokenDetails}"
                                                               Visibility="{Binding HasTokenDetails, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding DurationText}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Padding="24"
                    Visibility="{Binding EmptyVisibility}"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="暂无任务数据" />
                    <TextBlock Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="等待 Codex 任务" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="{Binding StatusText}" />
            <TextBlock Grid.Column="1"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="{Binding UpdatedText}" />
        </Grid>
    </Grid>
</Window>
