<Window x:Class="ThreadBeacon.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ThreadBeacon.App.Controls"
        Title="ThreadBeacon for Codex"
        Icon="Resources/AppIcon.ico"
        Width="620"
        Height="500"
        MinWidth="480"
        MinHeight="340"
        Background="{StaticResource WindowBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        Topmost="{Binding WindowPin.IsPinned}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="#E5484D" />
                <Ellipse Width="9" Height="9" Margin="0,3" Fill="#F5A524" />
                <Ellipse Width="9" Height="9" Fill="#30A46C" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="ThreadBeacon" />
                <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="Codex 任务状态" />
                    <TextBlock Margin="6,0,0,0"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="{Binding ThreadCountText}"
                               ToolTip="{Binding ThreadCountAccessibilityLabel}"
                               AutomationProperties.Name="{Binding ThreadCountAccessibilityLabel}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource ControlBorderBrush}"
                        Command="{Binding WindowPin.ToggleCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="钉在最前面" />
                            <Setter Property="AutomationProperties.Name" Value="钉在最前面" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WindowPin.IsPinned}" Value="True">
                                    <Setter Property="ToolTip" Value="取消钉住" />
                                    <Setter Property="AutomationProperties.Name" Value="取消钉住" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE718;" />
                                <Setter Property="Foreground"
                                        Value="{StaticResource SecondaryTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowPin.IsPinned}" Value="True">
                                        <Setter Property="Text" Value="&#xE841;" />
                                        <Setter Property="Foreground" Value="#0067C0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Button x:Name="SoundButton"
                        Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource ControlBorderBrush}"
                        Click="OnSoundButtonClick"
                        ToolTip="提示音设置"
                        AutomationProperties.Name="提示音设置">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="15"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="&#xE767;" />
                </Button>

                <Button Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource ControlBorderBrush}"
                        Command="{Binding Monitoring.ToggleCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="暂停监听" />
                            <Setter Property="AutomationProperties.Name" Value="暂停监听" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Monitoring.IsPaused}" Value="True">
                                    <Setter Property="ToolTip" Value="恢复监听" />
                                    <Setter Property="AutomationProperties.Name" Value="恢复监听" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE769;" />
                                <Setter Property="Foreground"
                                        Value="{StaticResource SecondaryTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Monitoring.IsPaused}" Value="True">
                                        <Setter Property="Text" Value="&#xE768;" />
                                        <Setter Property="Foreground" Value="#0067C0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Button Width="32"
                        Height="32"
                        Padding="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource ControlBorderBrush}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="刷新">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="15"
                               Text="&#xE72C;" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="14,0,14,7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="66" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="48" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="状态" />
            <TextBlock Grid.Column="2"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="任务" />
            <TextBlock Grid.Column="3"
                       HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="累计 Token" />
            <TextBlock Grid.Column="4"
                       HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="持续" />
        </Grid>

        <Grid Grid.Row="3">
            <ListBox ItemsSource="{Binding Threads}"
                     Visibility="{Binding ListVisibility}"
                     Background="{StaticResource SurfaceBrush}"
                     BorderBrush="{StaticResource ControlBorderBrush}"
                     BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Focusable" Value="False" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Border Height="48"
                                    Padding="13,0"
                                    BorderBrush="#ECECEE"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="66" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="48" />
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Width="8"
                                             Height="8"
                                             HorizontalAlignment="Left"
                                             Fill="{Binding StatusBrush}" />
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Text="{Binding StatusLabel}" />
                                    <Grid Grid.Column="2" Margin="0,0,12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock FontSize="13"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Title}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Text="{Binding IncidentDetailText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding HasIncidentDetail, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Height="22"
                                                Margin="6,0,0,0"
                                                Padding="2,0"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="{Binding SubagentToggleAccessibilityLabel}"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding ToggleSubagentsCommand}"
                                                ToolTip="{Binding SubagentToggleAccessibilityLabel}"
                                                Visibility="{Binding HasSubagents, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="9"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Text="&#xE70E;">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="LayoutTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="0" />
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSubagentExpanded}" Value="True">
                                                                    <Setter Property="LayoutTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="90" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="3,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Text="&#xE8AC;" />
                                                <TextBlock Margin="3,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Text="{Binding SubagentCountText}" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <StackPanel Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="11"
                                                   Text="{Binding TokenText}" />
                                        <controls:TokenInfoControl Margin="4,0,0,0"
                                                                   Details="{Binding TokenDetails}"
                                                                   Visibility="{Binding HasTokenDetails, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="4"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="{Binding DurationText}" />
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Subagents}"
                                          Visibility="{Binding ShowSubagentRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border MinHeight="52"
                                                Padding="27,7,13,7"
                                                Background="#08000000"
                                                BorderBrush="#ECECEE"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="72" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Top"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="10"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Text="&#xE72A;" />
                                                <Ellipse Grid.Column="1"
                                                         Width="6"
                                                         Height="6"
                                                         Margin="0,5,0,0"
                                                         HorizontalAlignment="Left"
                                                         VerticalAlignment="Top"
                                                         Fill="{Binding StatusBrush}" />
                                                <StackPanel Grid.Column="2" Margin="6,0,10,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock MaxWidth="86"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Text="{Binding Alias}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding Alias}"
                                                                   Visibility="{Binding HasAlias, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="4,0"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Text="|"
                                                                   Visibility="{Binding HasAlias, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <TextBlock Grid.Column="2"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Title}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding Title}" />
                                                    </Grid>
                                                    <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                                        <TextBlock FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusBrush}"
                                                                   Text="{Binding StatusLabel}" />
                                                        <TextBlock Margin="5,0"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Text="·" />
                                                        <TextBlock FontSize="10"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Text="{Binding ActivityText}"
                                                                   ToolTip="{Binding ActivityTooltip}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               Text="{Binding TokenText}" />
                                                    <controls:SubagentInfoControl Margin="4,0,0,0"
                                                                                  Details="{Binding Details}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Height="38"
                                    Padding="49,0,13,0"
                                    Background="#08000000"
                                    BorderBrush="#ECECEE"
                                    BorderThickness="0,0,0,1"
                                    Visibility="{Binding ShowSubagentPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="&#xE895;" />
                                    <TextBlock Margin="7,0,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="{Binding SubagentPlaceholderText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Padding="24"
                    Visibility="{Binding EmptyVisibility}"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="暂无任务数据" />
                    <TextBlock Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="等待 Codex 任务" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="{Binding StatusText}" />
            <TextBlock Grid.Column="1"
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="{Binding UpdatedText}" />
        </Grid>

        <Popup x:Name="SoundSettingsPopup"
               AllowsTransparency="True"
               HorizontalOffset="-228"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=SoundButton}"
               StaysOpen="False"
               VerticalOffset="6">
            <Border x:Name="SoundSettingsPanel"
                    Width="260"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Text="提示音" />
                    <CheckBox Margin="0,14,0,0"
                              Content="启用提示音"
                              IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                    <StackPanel Margin="0,10,0,0"
                                IsEnabled="{Binding IsCompletionConfigurationEnabled}">
                        <CheckBox Content="任务完成"
                                  IsChecked="{Binding IsCompletionEnabled, Mode=TwoWay}" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox MinWidth="132"
                                      Height="28"
                                      ItemsSource="{Binding AvailableSounds}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding SelectedCompletionSound, Mode=TwoWay}" />
                            <Button Grid.Column="1"
                                    Height="28"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    Command="{Binding PreviewCommand}"
                                    Content="试听" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
