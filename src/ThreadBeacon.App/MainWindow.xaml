<Window x:Class="ThreadBeacon.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ThreadBeacon.App.Controls"
        Title="ThreadBeacon for Codex"
        Icon="Resources/AppIcon.ico"
        Width="620"
        Height="500"
        MinWidth="480"
        MinHeight="340"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        TextOptions.TextFormattingMode="Display"
        Topmost="{Binding WindowPin.IsPinned}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="#E5484D" />
                <Ellipse Width="9" Height="9" Margin="0,3" Fill="#F5A524" />
                <Ellipse Width="9" Height="9" Fill="#30A46C" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="ThreadBeacon" />
                <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{DynamicResource CodexTaskStatus}" />
                    <TextBlock Margin="6,0,0,0"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding ThreadCountText}"
                               ToolTip="{Binding ThreadCountAccessibilityLabel}"
                               AutomationProperties.Name="{Binding ThreadCountAccessibilityLabel}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button x:Name="FavoritesFilterButton"
                        Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        Command="{Binding ToggleFavoritesOnlyCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="{DynamicResource ShowFavoritesOnly}" />
                            <Setter Property="AutomationProperties.Name" Value="{DynamicResource ShowFavoritesOnly}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowsFavoritesOnly}" Value="True">
                                    <Setter Property="ToolTip" Value="{DynamicResource ShowAllTasks}" />
                                    <Setter Property="AutomationProperties.Name" Value="{DynamicResource ShowAllTasks}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE734;" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SecondaryTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowsFavoritesOnly}" Value="True">
                                        <Setter Property="Text" Value="&#xE735;" />
                                        <Setter Property="Foreground" Value="#C98B00" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Button Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        Command="{Binding WindowPin.ToggleCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="{DynamicResource PinToFront}" />
                            <Setter Property="AutomationProperties.Name" Value="{DynamicResource PinToFront}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WindowPin.IsPinned}" Value="True">
                                    <Setter Property="ToolTip" Value="{DynamicResource Unpin}" />
                                    <Setter Property="AutomationProperties.Name" Value="{DynamicResource Unpin}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid Width="16" Height="16">
                        <TextBlock x:Name="WindowPinFillGlyph"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="15"
                                   Foreground="#0067C0"
                                   Text="&#xE841;"
                                   Visibility="{Binding WindowPin.IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock x:Name="WindowPinOutlineGlyph"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="15"
                                   Text="&#xE718;">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource SecondaryTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowPin.IsPinned}" Value="True">
                                            <Setter Property="Foreground" Value="#0067C0" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

                <Button x:Name="IgnoredTasksButton"
                        Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        Click="OnIgnoredTasksButtonClick"
                        ToolTip="{DynamicResource ManageIgnored}"
                        AutomationProperties.Name="{DynamicResource ManageIgnored}"
                        Visibility="{Binding HasIgnoredThreads, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="15"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="&#xED1A;" />
                </Button>

                <Button x:Name="SettingsButton"
                        Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        Click="OnSettingsButtonClick"
                        ToolTip="{DynamicResource Settings}"
                        AutomationProperties.Name="{DynamicResource Settings}">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="15"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="&#xE713;" />
                </Button>

                <Button Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        Click="OnAboutButtonClick"
                        ToolTip="{DynamicResource About}"
                        AutomationProperties.Name="{DynamicResource About}">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="15"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="&#xE946;" />
                </Button>

                <Button Width="32"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        Command="{Binding Monitoring.ToggleCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="{DynamicResource PauseMonitoring}" />
                            <Setter Property="AutomationProperties.Name" Value="{DynamicResource PauseMonitoring}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Monitoring.IsPaused}" Value="True">
                                    <Setter Property="ToolTip" Value="{DynamicResource ResumeMonitoring}" />
                                    <Setter Property="AutomationProperties.Name" Value="{DynamicResource ResumeMonitoring}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE769;" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SecondaryTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Monitoring.IsPaused}" Value="True">
                                        <Setter Property="Text" Value="&#xE768;" />
                                        <Setter Property="Foreground" Value="#0067C0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Button Width="32"
                        Height="32"
                        Padding="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="{DynamicResource Refresh}">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="15"
                               Text="&#xE72C;" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="14,0,14,7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="66" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="48" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{DynamicResource Status}" />
            <TextBlock Grid.Column="2"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{DynamicResource Task}" />
            <TextBlock Grid.Column="3"
                       HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{DynamicResource TotalToken}" />
            <TextBlock Grid.Column="4"
                       HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{DynamicResource Duration}" />
        </Grid>

        <Grid Grid.Row="3">
        <ListBox ItemsSource="{Binding Threads}"
                 Foreground="{DynamicResource PrimaryTextBrush}"
                 Visibility="{Binding ListVisibility}"
                     Background="{DynamicResource SurfaceBrush}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Focusable" Value="False" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Border Height="48"
                                    Padding="13,0"
                                    BorderBrush="#ECECEE"
                                    BorderThickness="0,0,0,1">
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{Binding FavoriteCommandLabel}"
                                                  Command="{Binding ToggleFavoriteCommand}" />
                                        <MenuItem Header="{Binding PinCommandLabel}"
                                                  Command="{Binding TogglePinCommand}" />
                                        <Separator />
                                        <MenuItem Header="{DynamicResource IgnoreTask}"
                                                  Command="{Binding IgnoreCommand}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="66" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="48" />
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Width="8"
                                             Height="8"
                                             HorizontalAlignment="Left"
                                             Fill="{Binding StatusBrush}" />
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Text="{Binding StatusLabel}" />
                                    <Grid Grid.Column="2" Margin="0,0,12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                 <TextBlock Margin="0,0,5,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="&#xE718;"
                                                            ToolTip="{DynamicResource PinnedTask}"
                                                            Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <TextBlock Margin="0,0,5,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="10"
                                                           Foreground="#C98B00"
                                                           Text="&#xE735;"
                                                           ToolTip="{DynamicResource FavoritedTask}"
                                                           Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <TextBlock Margin="0,0,5,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="&#xF03F;"
                                                           ToolTip="{DynamicResource ArchivedTask}"
                                                           Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <TextBlock FontSize="13"
                                                           Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Title}" />
                                            </StackPanel>
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding IncidentDetailText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding HasIncidentDetail, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Height="22"
                                                Margin="6,0,0,0"
                                                Padding="2,0"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="{Binding SubagentToggleAccessibilityLabel}"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding ToggleSubagentsCommand}"
                                                ToolTip="{Binding SubagentToggleAccessibilityLabel}"
                                                Visibility="{Binding HasSubagents, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="9"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="&#xE70E;">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="LayoutTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="0" />
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSubagentExpanded}" Value="True">
                                                                    <Setter Property="LayoutTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="90" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="3,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="&#xE8AC;" />
                                                <TextBlock Margin="3,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="{Binding SubagentCountText}" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <StackPanel Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="11"
                                                   Text="{Binding TokenText}" />
                                        <controls:TokenInfoControl Margin="4,0,0,0"
                                                                   Details="{Binding TokenDetails}"
                                                                   Visibility="{Binding HasTokenDetails, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="4"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding DurationText}" />
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Subagents}"
                                          Visibility="{Binding ShowSubagentRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border MinHeight="52"
                                                Padding="27,7,13,7"
                                                Background="#08000000"
                                                BorderBrush="#ECECEE"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="72" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Top"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="&#xE72A;" />
                                                <Ellipse Grid.Column="1"
                                                         Width="6"
                                                         Height="6"
                                                         Margin="0,5,0,0"
                                                         HorizontalAlignment="Left"
                                                         VerticalAlignment="Top"
                                                         Fill="{Binding StatusBrush}" />
                                                <StackPanel Grid.Column="2" Margin="6,0,10,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock MaxWidth="86"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   Text="{Binding Alias}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding Alias}"
                                                                   Visibility="{Binding HasAlias, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="4,0"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   Text="|"
                                                                   Visibility="{Binding HasAlias, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <TextBlock Grid.Column="2"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Title}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding Title}" />
                                                    </Grid>
                                                    <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                                        <TextBlock FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusBrush}"
                                                                   Text="{Binding StatusLabel}" />
                                                        <TextBlock Margin="5,0"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   Text="·" />
                                                        <TextBlock FontSize="10"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   Text="{Binding ActivityText}"
                                                                   ToolTip="{Binding ActivityTooltip}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               Text="{Binding TokenText}" />
                                                    <controls:SubagentInfoControl Margin="4,0,0,0"
                                                                                  Details="{Binding Details}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Height="38"
                                    Padding="49,0,13,0"
                                    Background="#08000000"
                                    BorderBrush="#ECECEE"
                                    BorderThickness="0,0,0,1"
                                    Visibility="{Binding ShowSubagentPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="&#xE895;" />
                                    <TextBlock Margin="7,0,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Text="{Binding SubagentPlaceholderText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Padding="24"
                    Visibility="{Binding EmptyVisibility}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,0,8"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="20"
                               Foreground="#C98B00"
                               Text="{Binding EmptyStateIcon}" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="{Binding EmptyStateTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding EmptyStateSubtitle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{Binding StatusText}" />
            <Button Grid.Column="1"
                    Width="28"
                    Height="24"
                    Margin="8,-3,0,-3"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Command="{Binding UpdateCheck.OpenReleaseCommand}"
                    ToolTip="{DynamicResource UpdateAvailable}"
                    AutomationProperties.Name="{DynamicResource UpdateAvailable}"
                    Visibility="{Binding UpdateCheck.IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock FontFamily="Segoe Fluent Icons"
                           FontSize="15"
                           Foreground="#C98B00"
                           Text="&#xE895;" />
            </Button>
            <controls:DataSourceHealthControl Grid.Column="2"
                                              Margin="8,-3,8,-3"
                                              Details="{Binding DataSourceHealth}" />
            <TextBlock Grid.Column="3"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{Binding UpdatedText}" />
        </Grid>

        <Popup x:Name="IgnoredTasksPopup"
               AllowsTransparency="True"
               HorizontalOffset="-248"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=IgnoredTasksButton}"
               StaysOpen="False"
               VerticalOffset="6">
            <Border Width="280"
                    Padding="14"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Margin="0,0,0,10"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{DynamicResource IgnoredTasks}" />
                    <ItemsControl ItemsSource="{Binding IgnoredThreads}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="32" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Title}" />
                                    <Button Grid.Column="1"
                                            Width="28"
                                            Height="28"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Command="{Binding RestoreCommand}"
                                            ToolTip="{DynamicResource RestoreTask}"
                                            AutomationProperties.Name="{DynamicResource RestoreTask}">
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   FontSize="14"
                                                   Text="&#xE777;" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator Margin="0,8"
                               Visibility="{Binding ShowRestoreAllIgnored, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button HorizontalAlignment="Left"
                            Padding="8,4"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Command="{Binding RestoreAllIgnoredCommand}"
                            Content="{DynamicResource RestoreAll}"
                            Visibility="{Binding ShowRestoreAllIgnored, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
