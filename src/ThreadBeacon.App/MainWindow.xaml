<Window x:Class="ThreadBeacon.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ThreadBeacon for Codex"
        Width="560"
        Height="440"
        MinWidth="440"
        MinHeight="320"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="#E5484D" />
                <Ellipse Width="9" Height="9" Margin="0,3" Fill="#F5A524" />
                <Ellipse Width="9" Height="9" Fill="#30A46C" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="ThreadBeacon" />
                <TextBlock Margin="0,2,0,0"
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="Codex 任务状态" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Padding="24"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Text="暂无任务数据" />
                <TextBlock Margin="0,6,0,0"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="等待只读数据源接入" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   FontSize="11"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   Text="监听尚未启动" />
    </Grid>
</Window>

