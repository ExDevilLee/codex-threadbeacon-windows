<Window x:Class="ThreadBeacon.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AboutTitle}"
        Icon="Resources/AppIcon.ico"
        Width="420"
        Height="570"
        MinWidth="380"
        MinHeight="520"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center">
            <Image Width="72" Height="72" Source="Resources/AppIcon.ico" />
            <TextBlock Margin="0,12,0,0"
                       HorizontalAlignment="Center"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="ThreadBeacon" />
            <TextBlock Margin="0,4,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{DynamicResource AboutTagline}" />
        </StackPanel>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
            <TextBlock HorizontalAlignment="Center"
                       Text="{DynamicResource AboutVersionLabel}" />
            <TextBlock HorizontalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{Binding VersionText}" />
            <Button Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    Padding="12,6"
                    Command="{Binding UpdateCheck.CheckCommand}"
                    Content="{DynamicResource CheckForUpdates}" />
            <TextBlock Margin="0,6,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{DynamicResource UpdateCheckIdle}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding UpdateCheck.Status}" Value="Checking">
                                <Setter Property="Text" Value="{DynamicResource CheckingForUpdates}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding UpdateCheck.Status}" Value="UpToDate">
                                <Setter Property="Text" Value="{DynamicResource UpToDate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding UpdateCheck.Status}" Value="Available">
                                <Setter Property="Text" Value="{DynamicResource UpdateAvailableVersion}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding UpdateCheck.Status}" Value="Failed">
                                <Setter Property="Text" Value="{DynamicResource UpdateCheckFailed}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <Button Margin="0,6,0,0"
                    HorizontalAlignment="Center"
                    Padding="12,6"
                    Command="{Binding UpdateCheck.OpenReleaseCommand}"
                    Content="{DynamicResource OpenRelease}"
                    Visibility="{Binding UpdateCheck.IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock TextWrapping="Wrap"
                       Text="{DynamicResource AboutDescription}" />
            <TextBlock Margin="0,14,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{DynamicResource AboutDisclaimer}" />
            <WrapPanel Margin="0,18,0,0" HorizontalAlignment="Center">
                <Button Margin="4" Padding="12,6" Click="OnLinkClick" Tag="https://github.com/ExDevilLee/codex-threadbeacon-windows" Content="{DynamicResource AboutRepository}" />
                <Button Margin="4" Padding="12,6" Click="OnLinkClick" Tag="https://github.com/ExDevilLee/codex-threadbeacon-windows/releases" Content="{DynamicResource AboutReleases}" />
                <Button Margin="4" Padding="12,6" Click="OnLinkClick" Tag="https://github.com/ExDevilLee/codex-threadbeacon-windows/blob/main/PRIVACY.md" Content="{DynamicResource AboutPrivacy}" />
                <Button Margin="4" Padding="12,6" Click="OnLinkClick" Tag="https://github.com/ExDevilLee/codex-threadbeacon-windows/blob/main/LICENSE" Content="{DynamicResource AboutLicense}" />
            </WrapPanel>
            <Button Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Padding="12,6"
                    Click="OnLinkClick"
                    Tag="https://github.com/ExDevilLee/codex-threadbeacon-windows/blob/main/SPONSOR.md"
                    Content="{DynamicResource AboutSupportProject}" />
            <TextBlock Margin="0,10,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="{DynamicResource AboutCopyright}" />
        </StackPanel>

        <Button Grid.Row="5"
                Width="90"
                HorizontalAlignment="Right"
                Padding="12,6"
                Click="OnCloseClick"
                Content="{DynamicResource Close}" />
    </Grid>
</Window>
