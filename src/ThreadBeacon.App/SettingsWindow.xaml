<Window x:Class="ThreadBeacon.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource SettingsTitle}"
        Icon="Resources/AppIcon.ico"
        Width="620"
        Height="680"
        MinWidth="400"
        MinHeight="520"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20,14,20,20">
        <TabControl Background="Transparent"
                    BorderBrush="{DynamicResource ControlBorderBrush}">
            <TabItem Header="{DynamicResource GeneralTab}">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource RefreshInterval}" />
                        <TextBlock Margin="0,4,18,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{DynamicResource RefreshIntervalDescription}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                              Height="30"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding Display.RefreshIntervalOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding Display.RefreshIntervalSeconds, Mode=TwoWay}" />

                    <TextBlock Grid.Row="2"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{DynamicResource Language}" />
                    <ComboBox Grid.Row="2"
                              Grid.Column="1"
                              Height="30"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding Display.LanguageOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding Display.Language, Mode=TwoWay}" />

                    <TextBlock Grid.Row="4"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{DynamicResource Theme}" />
                    <ComboBox Grid.Row="4"
                              Grid.Column="1"
                              Height="30"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding Display.ThemeOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding Display.Theme, Mode=TwoWay}" />

                    <StackPanel Grid.Row="6">
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource LaunchAtLogin}" />
                        <TextBlock Margin="0,4,18,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource LaunchAtLoginDescription}" />
                    </StackPanel>
                    <CheckBox Grid.Row="6"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Content="{DynamicResource EnableLaunchAtLogin}"
                              IsChecked="{Binding Startup.IsEnabled, Mode=TwoWay}" />

                    <StackPanel Grid.Row="8">
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource MaximumTaskCount}" />
                        <TextBlock Margin="0,4,18,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{DynamicResource MaximumTaskCountDescription}" />
                    </StackPanel>
                    <ComboBox Grid.Row="8"
                              Grid.Column="1"
                              Height="30"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding Display.MaximumTaskCountOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding Display.MaximumTaskCount, Mode=TwoWay}" />
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource SoundsTab}">
                <StackPanel Margin="18">
                    <CheckBox Content="{DynamicResource EnableSounds}"
                              IsChecked="{Binding Sound.IsEnabled, Mode=TwoWay}" />

                    <CheckBox Margin="0,16,0,0"
                              Content="{DynamicResource TaskCompletion}"
                              IsChecked="{Binding Sound.IsCompletionEnabled, Mode=TwoWay}"
                              IsEnabled="{Binding Sound.IsCompletionCategoryEnabled}" />
                    <StackPanel Margin="20,8,0,0"
                                IsEnabled="{Binding Sound.IsCompletionSoundEnabled}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Height="30"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding Sound.AvailableSounds}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Sound.SelectedCompletionSound, Mode=TwoWay}" />
                            <Button Grid.Column="1"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Padding="14,0"
                                    Command="{Binding Sound.PreviewCommand}"
                                    Content="{DynamicResource Preview}" />
                        </Grid>
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBlock Width="150"
                                       VerticalAlignment="Center"
                                       Text="{Binding Sound.CompletionSoundPathText}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Sound.CompletionSoundPath}" />
                            <Button Margin="8,0,0,0"
                                    Padding="10,4"
                                    Command="{Binding Sound.SelectCompletionSoundCommand}"
                                    Content="{DynamicResource SelectCustomSound}" />
                            <Button Margin="8,0,0,0"
                                    Padding="10,4"
                                    Command="{Binding Sound.ClearCompletionSoundCommand}"
                                    Content="{DynamicResource ClearCustomSound}" />
                        </StackPanel>
                    </StackPanel>

                    <Separator Margin="0,16,0,14" />

                    <CheckBox Content="{DynamicResource ServiceIncident}"
                              IsChecked="{Binding Sound.IsWarningEnabled, Mode=TwoWay}"
                              IsEnabled="{Binding Sound.IsWarningCategoryEnabled}" />
                    <StackPanel Margin="20,8,0,0"
                                IsEnabled="{Binding Sound.IsWarningSoundEnabled}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Height="30"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding Sound.AvailableSounds}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Sound.SelectedWarningSound, Mode=TwoWay}" />
                            <Button Grid.Column="1"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Padding="14,0"
                                    Command="{Binding Sound.WarningPreviewCommand}"
                                    Content="{DynamicResource Preview}" />
                        </Grid>
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <TextBlock Width="150"
                                       VerticalAlignment="Center"
                                       Text="{Binding Sound.WarningSoundPathText}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Sound.WarningSoundPath}" />
                            <Button Margin="8,0,0,0"
                                    Padding="10,4"
                                    Command="{Binding Sound.SelectWarningSoundCommand}"
                                    Content="{DynamicResource SelectCustomSound}" />
                            <Button Margin="8,0,0,0"
                                    Padding="10,4"
                                    Command="{Binding Sound.ClearWarningSoundCommand}"
                                    Content="{DynamicResource ClearCustomSound}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="{DynamicResource AutoRecoveryTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <CheckBox FontWeight="SemiBold"
                                  Content="{DynamicResource EnableAutoRecovery}"
                                  IsChecked="{Binding AutoRecovery.IsEnabled, Mode=TwoWay}" />
                        <TextBlock Margin="20,6,0,14"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource AutoRecoveryDescription}" />

                        <ItemsControl ItemsSource="{Binding AutoRecovery.Rules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox VerticalAlignment="Top"
                                                  Margin="0,6,12,0"
                                                  FontWeight="SemiBold"
                                                  Content="{Binding DisplayName}"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                                        <TextBox Grid.Column="1"
                                                 MinHeight="48"
                                                 MaxLength="500"
                                                 Padding="6,4"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding Prompt, Mode=TwoWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,4,0,12" />
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Padding="10,3"
                                    Command="{Binding AutoRecovery.RefreshHistoryCommand}"
                                    Content="{DynamicResource Refresh}" />
                            <TextBlock FontSize="14"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{DynamicResource RecoveryHistory}" />
                        </DockPanel>
                        <DataGrid Height="150"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  ItemsSource="{Binding AutoRecovery.History}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="*"
                                                    Header="{DynamicResource RecoveryTaskId}"
                                                    Binding="{Binding ThreadId}" />
                                <DataGridTextColumn Width="130"
                                                    Header="{DynamicResource RecoveryIncident}"
                                                    Binding="{Binding Incident}" />
                                <DataGridTextColumn Width="80"
                                                    Header="{DynamicResource RecoveryStatus}"
                                                    Binding="{Binding Status}" />
                                <DataGridTextColumn Width="145"
                                                    Header="{DynamicResource RecoveryUpdatedAt}"
                                                    Binding="{Binding UpdatedAt}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
